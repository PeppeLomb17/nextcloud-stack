# ------------------------------
# Nextcloud application settings
# ------------------------------
NEXTCLOUD_PORT=8080
NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=change_me_db_password
NEXTCLOUD_DB_HOST=postgres

# ------------------------------
# PostgreSQL settings
# ------------------------------
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
